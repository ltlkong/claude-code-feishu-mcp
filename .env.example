# 飞书应用凭证（在 https://open.feishu.cn/app 创建应用后获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# （可选）限制允许使用的飞书用户 ID，逗号分隔。留空允许所有用户
# ALLOWED_USER_IDS=ou_xxx,ou_yyy

# （可选）ElevenLabs 语音合成 & 语音转写
# 依赖：brew install ffmpeg
# ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# （可选）临时文件目录
# TEMP_DIR=/tmp/feishu-channel

# （可选）Heartbeat — 基于对话历史的主动消息
# chat_id 从对话记录自动获取，不需要手动配置
# HEARTBEAT_MODEL=haiku
# HEARTBEAT_INTERVAL_MINUTES=10
# HEARTBEAT_INACTIVITY_MINUTES=10
