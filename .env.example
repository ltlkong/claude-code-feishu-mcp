# 飞书应用凭证（在 https://open.feishu.cn/app 创建应用后获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# （可选）限制允许使用的飞书用户 ID，逗号分隔。留空允许所有用户
# ALLOWED_USER_IDS=ou_xxx,ou_yyy

# （可选）ElevenLabs 语音合成 & 语音转写
# 依赖：brew install ffmpeg
# ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# （可选）临时文件目录
# TEMP_DIR=/tmp/feishu-channel

# （可选）Heartbeat — 定时提醒 Claude 查看聊天
# HEARTBEAT_INTERVAL_MINUTES=15
# HEARTBEAT_INACTIVITY_MINUTES=5

# （可选）图片/GIF 搜索 API
# PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TENOR_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# （可选）模型 Provider
# XIAOBAI_PROVIDER=claude  # claude | gemini | cursor
# GEMINI_COMMAND=gemini
# GEMINI_ARGS=--yolo --model gemini-3.1-flash-lite-preview
# GEMINI_TIMEOUT_SECONDS=120
# CURSOR_COMMAND=cursor-agent
# CURSOR_ARGS=
# CURSOR_PROMPT_FLAG=-p
# CURSOR_TIMEOUT_SECONDS=120

# （可选）微信 iLink — 扫码登录后 token 自动保存，无需手动配置
# WECHAT_QR_NOTIFY_CHAT_ID=oc_xxx  # 飞书群 ID，用于发送微信登录二维码
